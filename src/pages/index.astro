---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/path';

const albums = (await getCollection('albums')).sort(
  (a, b) => b.data.year - a.data.year,
);
---

<BaseLayout title="JiangJingyi · Music">
  <section class="text-center mb-16">
    <h1 class="font-display text-5xl md:text-6xl text-goldleaf text-shadow-candle mb-4 tracking-wider">
      MUSICA SACRA
    </h1>
    <p class="font-body italic text-ochre text-lg max-w-2xl mx-auto">
      Personal liturgical & contemplative works · Produced with SUNO ·
      个人音乐作品集
    </p>
    <div class="divider-ornate w-48 mx-auto mt-6"></div>
  </section>

  <section class="grid grid-cols-1 md:grid-cols-2 gap-10">
    {
      albums.map((album) => (
        <a
          href={withBase(`/albums/${album.id}/`)}
          class="group block border border-brass/30 hover:border-goldleaf transition-all duration-300 p-6 bg-black/20 backdrop-blur-sm"
        >
          <div class="aspect-square overflow-hidden mb-5 border border-brass/20">
            <img
              src={withBase(album.data.cover)}
              alt={album.data.title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
          </div>
          <h2 class="font-display text-2xl text-goldleaf mb-2 group-hover:text-candle transition-colors">
            {album.data.title}
          </h2>
          {album.data.subtitle && (
            <p class="font-body italic text-ochre text-sm leading-relaxed">
              {album.data.subtitle}
            </p>
          )}
          <p class="text-parchment/60 text-xs mt-3 font-mono tracking-widest">
            {album.data.year} · {album.data.songs.length} TRACKS
          </p>
        </a>
      ))
    }
  </section>
</BaseLayout>
