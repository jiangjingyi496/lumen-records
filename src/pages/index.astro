---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/path';

const albums = (await getCollection('albums')).sort(
  (a, b) => b.data.year - a.data.year,
);

// 网格响应实际专辑数量：≤2 显示 2 列，3 张 3 列，4+ 张满 4 列
const gridClass =
  albums.length <= 2
    ? 'grid-cols-1 sm:grid-cols-2 max-w-3xl mx-auto'
    : albums.length === 3
    ? 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 max-w-5xl mx-auto'
    : 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-4';
---

<BaseLayout title="Juniper Jing · Stella Matutina">
  {/* Hero · Stella Matutina */}
  <section class="relative text-center mb-2 md:mb-3 py-6 md:py-10 overflow-hidden">

    <h1 class="font-display text-3xl md:text-5xl lg:text-6xl text-junipergold tracking-[0.2em] mb-5 leading-tight">
      STELLA MATUTINA
    </h1>
    <p class="font-body italic text-goldleaf/85 text-xl md:text-2xl tracking-wider mb-3">
      Medieval Troubadour · Celtic Folk · Gregorian Chant
    </p>
    <p class="text-parchment/75 text-lg md:text-xl font-body italic max-w-2xl mx-auto">
      晨星 · 中世纪游吟诗人、凯尔特民谣、格里高利圣咏 · 个人创作分享
    </p>
    <div class="flex items-center justify-center gap-4 mt-6">
      <span class="h-px bg-goldleaf/40 w-16 md:w-24"></span>
      <span class="text-goldleaf/65 text-sm tracking-[0.3em]">⋆ MUSIC · SACRA ⋆</span>
      <span class="h-px bg-goldleaf/40 w-16 md:w-24"></span>
    </div>
  </section>

  {/* Hero ↔ 专辑网格之间的装饰间隔: 十字光环 (SVG 5)
     再放大 1.5× → h-24 md:h-[120px] (96/120px) */}
  <div class="flex justify-center mb-4 md:mb-6">
    <img
      src={withBase('/brand/divider-cross-halo.svg')}
      alt=""
      aria-hidden="true"
      class="h-24 md:h-[120px] w-auto opacity-90"
    />
  </div>

  {/* 专辑网格 · 响应专辑数量自适应列数 */}
  <section class={`grid ${gridClass} gap-6 md:gap-8`}>
    {
      albums.map((album) => (
        <a
          href={withBase(`/albums/${album.id}/`)}
          class="group block border border-goldleaf/20 hover:border-goldleaf/60 transition-all duration-500 p-5 bg-black/30 backdrop-blur-sm hover:bg-black/40"
        >
          <div class="aspect-square overflow-hidden mb-5 border border-goldleaf/10">
            <img
              src={withBase(album.data.cover)}
              alt={album.data.title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
          </div>
          <h2 class="font-display text-xl md:text-2xl text-goldleaf mb-2 group-hover:text-junipergold transition-colors tracking-wider leading-snug">
            {album.data.title}
          </h2>
          {album.data.subtitle && (
            <p class="font-body italic text-ochre/85 text-xl leading-relaxed">
              {album.data.subtitle}
            </p>
          )}
          <p class="text-parchment/50 text-lg mt-4 font-mono tracking-[0.25em]">
            {album.data.year} · {album.data.songs.length} TRACKS
          </p>
        </a>
      ))
    }
  </section>

  {/* Footer divider tag · 仿 Lovart "MUSIC SACRA" 风格 */}
  <section class="text-center mt-20">
    <div class="flex items-center justify-center gap-4">
      <span class="h-px bg-goldleaf/30 flex-1 max-w-[200px]"></span>
      <span class="text-goldleaf/60 text-base md:text-lg tracking-[0.4em] uppercase font-display">Et lux in tenebris lucet</span>
      <span class="h-px bg-goldleaf/30 flex-1 max-w-[200px]"></span>
    </div>
    <p class="text-parchment/45 text-lg mt-3 font-body italic">"光在黑暗中照耀"</p>
  </section>
</BaseLayout>
