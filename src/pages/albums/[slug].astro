---
import { getCollection, render } from 'astro:content';
import { marked } from 'marked';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ApplePlayer from '../../components/ApplePlayer.astro';
import { withBase } from '../../lib/path';

export async function getStaticPaths() {
  const albums = await getCollection('albums');
  return albums.map((album) => ({
    params: { slug: album.id },
    props: { album },
  }));
}

const { album } = Astro.props;
const { Content } = await render(album);

const coverUrl = withBase(album.data.cover);
const songsWithBase = album.data.songs.map((s) => ({
  ...s,
  audio: withBase(s.audio),
  lrc: s.lrc ? withBase(s.lrc) : s.lrc,
}));

const linerEnHtml = album.data.linerEn ? marked.parse(album.data.linerEn) : '';
const descriptionHtml = album.data.description ? marked.parse(album.data.description) : '';
const descriptionEnHtml = album.data.descriptionEn ? marked.parse(album.data.descriptionEn) : '';
---

<BaseLayout title={`${album.data.title} · JiangJingyi`} description={album.data.subtitle}>
  <style is:inline set:html={`:root { --page-accent: ${album.data.accentColor}; --page-bg: ${album.data.bgColor}; }`}></style>
  <article class="max-w-6xl mx-auto" id="album-root">
    <a
      href={withBase('/')}
      class="inline-block mb-6 text-lg text-ochre/70 hover:text-candle font-mono tracking-widest"
    >
      ← BACK TO ALBUMS
    </a>

    <header class="mb-8">
      <p class="font-mono text-base tracking-widest text-ochre/70 mb-2">
        {album.data.year} · {album.data.artist}
      </p>
      <h1 class="font-display text-3xl md:text-5xl text-goldleaf text-shadow-candle mb-2 leading-tight">
        {album.data.title}
      </h1>
      {album.data.subtitle && (
        <p class="font-body italic text-ochre text-2xl leading-relaxed">{album.data.subtitle}</p>
      )}
    </header>

    <section class="mb-12">
      <ApplePlayer
        songs={songsWithBase}
        cover={coverUrl}
        artist={album.data.artist}
        albumTitle={album.data.title}
        bgColor={album.data.bgColor}
        accentColor={album.data.accentColor}
      />
    </section>

    {descriptionHtml && (
      <section class="mb-10">
        <h2 class="font-display text-sm tracking-[0.3em] text-ochre mb-4">⟁ ABOUT ⟁</h2>
        <div class="about-body text-parchment/85 leading-relaxed font-body text-lg" set:html={descriptionHtml} />
      </section>
    )}

    <div class="divider-ornate mb-8"></div>

    <section class="prose-liner">
      <h2 class="font-display text-sm tracking-[0.3em] text-ochre mb-4">⟁ LINER NOTES ⟁</h2>
      <div class="text-parchment/85 leading-loose font-body">
        <Content />
      </div>
    </section>

    {(album.data.descriptionEn || linerEnHtml) && (
      <>
        <div class="my-16 flex items-center gap-4">
          <div class="flex-1 h-px bg-brass/30"></div>
          <span class="font-mono text-xs tracking-[0.4em] text-ochre/60">ENGLISH</span>
          <div class="flex-1 h-px bg-brass/30"></div>
        </div>
        {descriptionEnHtml && (
          <section class="mb-10">
            <div class="about-body text-parchment/85 leading-relaxed font-body text-lg" set:html={descriptionEnHtml} />
          </section>
        )}
        {linerEnHtml && (
          <section class="prose-liner">
            <div class="liner-en text-parchment/85 leading-loose font-body" set:html={linerEnHtml} />
          </section>
        )}
      </>
    )}
  </article>

  <style is:global>
    /* ABOUT 段落 (中英都用): marked 渲染出 <p>, 段间留 1rem */
    #album-root .about-body p {
      margin-bottom: 1rem;
    }
    #album-root .about-body p:last-child {
      margin-bottom: 0;
    }
    #album-root .about-body strong {
      color: inherit;
      font-weight: 700;
    }
    #album-root .about-body em {
      color: inherit;
      font-style: italic;
    }

    /* 英文 liner notes 由 marked 渲染, 给它跟中文一致的排版风格 */
    #album-root .liner-en h2 {
      font-family: 'Cinzel', 'Trajan Pro', serif;
      color: var(--page-accent, #c9a35a);
      font-size: 1.15rem;
      letter-spacing: 0.04em;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
    }
    #album-root .liner-en p {
      margin-bottom: 1rem;
    }
    #album-root .liner-en blockquote {
      border-left: 2px solid var(--page-accent, #c9a35a);
      padding-left: 1rem;
      margin: 1rem 0;
      color: rgba(230, 220, 198, 0.85);
      font-style: italic;
    }
    #album-root .liner-en ul {
      padding-left: 1.5rem;
      list-style: disc;
      margin-bottom: 1rem;
    }
    #album-root .liner-en ul li {
      margin-bottom: 0.5rem;
    }
    /* strong / em 不换色, 跟周围正文同色, 只用粗体/斜体本身做区分 */
    #album-root .liner-en strong {
      color: inherit;
      font-weight: 700;
    }
    #album-root .liner-en em {
      color: inherit;
      font-style: italic;
    }
  </style>
</BaseLayout>
